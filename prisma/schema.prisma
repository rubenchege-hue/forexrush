generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LicenseCode {
  id          String   @id @default(cuid())
  code        String   @unique
  clientName  String
  email       String
  status      String   @default("active") // active, redeemed, expired
  issuedAt    DateTime @default(now())
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  competitors Competitor[]
}

model Competition {
  id              String   @id @default(cuid())
  title           String
  description     String?
  entryFee        Float    @default(10.0)
  prizePool       Float
  startDate       DateTime
  endDate         DateTime
  status          String   @default("upcoming") // upcoming, active, completed
  maxParticipants Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitors Competitor[]
  trades      Trade[]        @relation(onDelete: Cascade)
}

model Competitor {
  id            String   @id @default(cuid())
  licenseCodeId String?
  competitionId String
  username      String
  displayName   String
  avatar        String?
  initialBalance Float   @default(10000.0)
  currentBalance Float   @default(10000.0)
  totalPnl      Float    @default(0.0)
  totalTrades   Int      @default(0)
  winRate       Float    @default(0.0)
  enrolledAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  licenseCode LicenseCode?  @relation(fields: [licenseCodeId], references: [id])
  competition Competition  @relation(fields: [competitionId], references: [id])
  trades      Trade[]        @relation(onDelete: Cascade)

  @@unique([competitionId, username])
}

model Trade {
  id            String   @id @default(cuid())
  competitorId  String
  competitionId String
  pair          String
  direction     String   // "long" or "short"
  lotSize       Float
  entryPrice    Float
  exitPrice     Float?
  pnl           Float    @default(0.0)
  status        String   @default("open")
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competitor  Competitor  @relation(fields: [competitorId], references: [id])
  competition Competition @relation(fields: [competitionId], references: [id])
}